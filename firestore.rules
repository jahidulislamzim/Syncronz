rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user exists in users and is authorized
    function isAuthorized() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAuthorized == true;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
        (exists(/databases/$(database)/documents/settings/admin) && 
         get(/databases/$(database)/documents/settings/admin).data.email == request.auth.token.email)
      );
    }

    // User Profile Rules
    match /users/{userId} {
      // Any authenticated user can read profiles (to show member names/avatars)
      allow read: if request.auth != null;
      // Any authenticated user can create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;
      // Owners can update their own profile fields except isAdmin and isAuthorized. Authorized users can update any profile.
      allow update: if request.auth != null && (
        (request.auth.uid == userId && 
         request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false) && 
         request.resource.data.get('isAuthorized', true) == resource.data.get('isAuthorized', true)) ||
        isAuthorized()
      );
      // Owners or authorized users can delete a profile
      allow delete: if request.auth != null && (request.auth.uid == userId || isAuthorized());

      // User's private notifications
      match /notifications/{notificationId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }

      // User's focus sessions
      match /focusSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Board Rules & Subcollections (boards, members, tasks, activity)
    match /boards/{boardId} {
      allow read, write: if isAuthorized();
      
      match /{allChildren=**} {
        allow read, write: if isAuthorized();
      }
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAuthorized() && isAdmin();
    }

    // Invited Users collection
    match /invited_users/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAuthorized() || request.auth.token.email.lower() == email);
    }

    // Test collection for database connection validation
    match /test/connection {
      allow read: if true;
    }
  }
}
