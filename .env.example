# NEXT_PUBLIC_ADMIN_EMAIL: Bootstrap fallback admin email.
# After first launch, set the admin email in the Firestore document `settings/admin { email: "..." }`.
# The Firestore value takes precedence. This env var is only used if the Firestore doc doesn't exist.
NEXT_PUBLIC_ADMIN_EMAIL="admin@example.com"

# --- FIREBASE CLIENT CONFIGURATION ---
# Replace with your own Firebase project values.
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_DATABASE_URL="https://YOUR_PROJECT-default-rtdb.firebaseio.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_PROJECT"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="1:YOUR_APP_ID:web:YOUR_WEB_HASH"
NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID="YOUR_DATABASE_ID"

# --- SMTP ENCRYPTION CONFIGURATION ---
# 32-byte hex key used to encrypt/decrypt SMTP credentials stored in Firestore.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SMTP_ENCRYPTION_KEY="generate-a-32-byte-hex-key-here"

# --- GOOGLE DRIVE OAUTH (for Drive integration) ---
# Create a Web OAuth 2.0 client in Google Cloud Console → Credentials → Create Credentials → OAuth client ID
# Use the same project as Firebase. Add http://localhost:3000 to Authorized JavaScript origins.
# GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxx"
